{
  "name": "nextjs-ts-tailwind-template",
  "version": "0.1.3",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "next:lint": "oxlint .",
    "lint": "pnpm run next:lint && oxlint 'src/**/*.{js,jsx,ts,tsx}'",
    "fmt": "oxfmt --write 'src/**/*.{js,jsx,ts,tsx,scss}'",
    "check-types": "tsc",
    "validate": "pnpm run fmt & pnpm run lint & pnpm run check-types && pnpm run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "16.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm run lint"
    ],
    "*.{js,jsx,ts,tsx,scss}": [
      "pnpm run fmt"
    ]
  },
  "packageManager": "pnpm@10.15.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3"
    }
  }
}
